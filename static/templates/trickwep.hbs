{{#*inline "_trickforms"}}
<div class="flexrow items-list">
  <h3 class="form-header">{{ localize "SGEH.sheet.trick.details" }}</h3>
  </div>
<ol class="items-list trick list">
  {{#each item.system.states}}
  <li class="trick-form-drop form-group trick-state-controls" data-state-id="{{@key}}">
    
    <input type="text" name="system.states.{{@key}}.label" value="{{this.label}}"/>
    <div class="form-fields">
      <ul class="traits-list">
        {{#each this.components as |id|}}
        <li class="tag trick-form-control" data-form-id="{{id}}" data-action="edit">
          {{#with ../../item.system.forms as |forms|}}
          {{sgeh-formName id forms}}
          {{/with}}
        </li>
        {{/each}}
      </ul>
    </div>
    <div class="trick-state-controls item-controls">
      <a class="trick-state-control" data-action="activate" data-tooltip="SGEH.sheet.trick.activateTip" aria-describedby="tooltip">
        <i class="fa-solid fa-arrow-up-from-bracket"></i>
      </a>
      <a class="trick-state-control" data-action="deactivate" data-tooltip="SGEH.sheet.trick.deactivateTip" aria-describedby="tooltip">
        <i class="fa-solid fa-download"></i>
      </a>
<a class="trick-state-control" data-action="delete" data-tooltip="SGEH.sheet.trick.deleteTip" aria-describedby="tooltip">
        <i class="fa-solid fa-trash"></i>
      </a>

    </div>
  </li>
  {{/each}}
  <li>
    <div class="trick-state-controls flexrow float-right">
      <a class="trick-state-control" 
         data-action="create" 
         data-tooltip="SGEH.sheet.trick.createTip">
        <i class="fas fa-plus"></i>{{localize 'DND5E.Add'}}
      </a>
    </div>
  </li>
</ol>
{{/inline}}


<form class="{{cssClass}} flexcol" autocomplete="off">

    {{!-- Item Sheet Header --}}
    <header class="sheet-header flexrow">
        <img class="profile" src="{{item.img}}" data-tooltip="{{item.name}}" data-edit="img"/>

        <div class="header-details flexrow">
            <h1 class="charname">
              {{#if system.identified}}
              <input name="name" type="text" value="{{item.name}}" placeholder="{{ localize 'DND5E.ItemName' }}">
              {{else}}
              <input name="system.unidentified.name" type="text" value="{{system.unidentified.name}}"
                     placeholder="{{ localize 'DND5E.NameUnidentified' }}">
              {{/if}}
            </h1>

            <div class="item-subtitle">
                <h4 class="item-type">{{itemType}}</h4>
                <span class="item-status">{{itemStatus}}</span>
            </div>

            <ul class="summary flexrow">
                <li>
                    {{lookup config.weaponTypes system.weaponType }}
                </li>
                <li>
                    <select name="system.rarity">
                        {{selectOptions config.itemRarity selected=system.rarity blank=""}}
                    </select>
                </li>
                <li>
                  {{> "dnd5e.item-source"}}
                </li>
            </ul>
        </div>
    </header>

    {{!-- Item Sheet Navigation --}}
    <nav class="sheet-navigation tabs" data-group="primary">
        <a class="item active" data-tab="description">{{ localize "DND5E.Description" }}</a>
        <a class="item" data-tab="details">{{ localize "DND5E.Details" }}</a>
        <a class="item" data-tab="effects">{{ localize "DND5E.Effects" }}</a>
    </nav>

    {{!-- Item Sheet Body --}}
    <section class="sheet-body">

        {{!-- Description Tab --}}
        {{> "dnd5e.item-description"}}

        {{!-- Details Tab --}}
        <div class="tab details" data-group="primary" data-tab="details">
            {{#dnd5e-concealSection concealDetails}}

            {{!-- Trick Forms Template --}}
            {{> "_trickforms"}}

            {{!-- Attunement/Proficiency --}}
            <div class="form-group">
                <label>{{localize "DND5E.Attunement"}}</label>
                <select name="system.attunement" data-dtype="Number">
                    {{selectOptions config.attunements selected=system.attunement}}
                </select>
            </div>

            <div class="form-group">
                <label>{{localize "DND5E.Proficiency"}}</label>
                <select name="system.proficient" data-dtype="Number">
                    {{selectOptions config.weaponAndArmorProficiencyLevels selected=system.proficient
                                    }}
                </select>
            </div>

            {{!-- Equipment Status --}}
            <div class="form-group stacked">
                <label>{{ localize "DND5E.ItemEquipmentStatus" }}</label>
                <label class="checkbox">
                    <input type="checkbox" name="system.identified" {{checked system.identified}}/> {{ localize "DND5E.Identified" }}
                </label>
            </div>

            <h3 class="form-header">{{ localize "DND5E.ItemWeaponUsage" }}</h3>

            {{!-- Item Activation Template --}}
            {{> "dnd5e.item-activation"}}

            <h3 class="form-header">{{ localize "DND5E.ItemWeaponAttack" }}</h3>

            {{!-- Item Action Template --}}
            {{> "dnd5e.item-action"}}


            {{/dnd5e-concealSection}}
        </div>

        {{!-- Effects Tab --}}
        <div class="tab effects flexcol" data-group="primary" data-tab="effects">
            {{> "dnd5e.active-effects"}}
        </div>
    </section>
</form>
