            "banner": "modules/steinhardt-guide-to-the-eldritch-hunt-zh-tw/static/assets/cutouts/banners/compendium.webp",
            "system": "dnd5e"
        }
    ],
    "packFolders": [
        {
            "name": "Steinhardt's Guide (zh-TW)",
            "color": "#140b1c",
            "packs": [
                "sgeh-tables",
                "sgeh-stories",
                "sgeh-notes",
                "sgeh-items",
                "sgeh-foes"
            ]
        }
    ],
    "documentTypes": {
        "Item": {
            "trickwep": {
                "htmlFields": [
                    "description.value",
                    "description.chat",
                    "description.unidentified"
                ],
                "filePathFields": {
                    "img": [
                        "IMAGE"
                    ]
                }
            }
        }
    },
    "externals": [],
