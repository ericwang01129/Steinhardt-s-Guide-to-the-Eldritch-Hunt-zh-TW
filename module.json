        "minimum": "11",
        "verified": "11.315"
    },
    "relationships": {
        "systems": [
            {
                "id": "dnd5e",
                "compatibility": {
                    "minimum": "3.1.0",
                    "verified": "3.1.2",
                    "maximum": "3.3.0"
                }
            }
        ],
        "requires": [
            {
                "id": "babele",
                "type": "module",
                "reason": "Provides the runtime that consumes the bundled zh-TW translation tables under compendium/."
            },
            {
                "id": "foundry_zh-tw",
                "type": "module",
                "reason": "Provides the zh-TW core locale that activates this module's Babele translation registration (lang='zh-tw')."
            }
        ]
    },
