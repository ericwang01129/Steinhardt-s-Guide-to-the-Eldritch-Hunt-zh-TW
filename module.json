            "label": "Steinhardt's Stories",
            "banner": "modules/steinhardt-guide-to-the-eldritch-hunt-zh-tw/static/assets/cutouts/banners/compendium.webp",
            "system": "dnd5e"
        },
        {
            "name": "sgeh-notes",
            "path": "packs/sgeh-notes",
            "type": "JournalEntry",
            "label": "Steinhardt's Notes",
            "banner": "modules/steinhardt-guide-to-the-eldritch-hunt-zh-tw/static/assets/cutouts/banners/compendium.webp",
            "system": "dnd5e"
        },
        {
            "name": "sgeh-items",
            "path": "packs/sgeh-items",
